---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Padres | Colegio Roger Bacon"
  description="Información institucional para padres de familia del Colegio Roger Bacon."
  path="/padres"
>
  <section class="blank-page" aria-label="Contenido padres">
    <div class="blank-page__band"></div>
    <div class="blank-page__space"></div>
  </section>
</BaseLayout>

<style>
  .blank-page__band {
    height: 56px;
    background: #f5f5f5;
    border-top: 1px solid #eceff2;
    border-bottom: 1px solid #eceff2;
  }

  .blank-page__space {
    min-height: 340px;
    background: #ffffff;
  }
</style>
