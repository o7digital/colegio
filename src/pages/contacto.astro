---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contacto | Colegio Roger Bacon"
  description="Contáctanos para recibir informes de admisión y atención institucional del Colegio Roger Bacon."
  path="/contacto"
>
  <section class="page-hero">
    <div class="container">
      <h1>Tu camino al éxito comienza aquí</h1>
      <p>Contáctanos para resolver tus dudas sobre admisión, oferta académica y vida escolar.</p>
    </div>
  </section>

  <section class="section">
    <div class="container split">
      <article>
        <h2 class="section-title">Escríbenos</h2>
        <p class="section-intro">
          Puedes comunicarte con nosotros por teléfono o correo electrónico. Nuestro equipo te brindará
          atención personalizada para el proceso de admisión.
        </p>
        <div class="contact-grid">
          <div class="card">
            <h3>Llámanos</h3>
            <p><a href="tel:+522226043466">(+052) 2226 04 34 66</a></p>
          </div>
          <div class="card">
            <h3>Correo</h3>
            <p><a href="mailto:contacto@colegio-rogerbacon.edu.mx">contacto@colegio-rogerbacon.edu.mx</a></p>
          </div>
          <div class="card">
            <h3>Visítanos</h3>
            <p>Av. 16 Ote. #233, Humboldt Norte C.P. 72570, Puebla, Pue. México</p>
          </div>
        </div>
      </article>

      <aside class="card">
        <h2>Facebook institucional</h2>
        <p>
          Sigue nuestras actividades y avisos en
          <a href="https://www.facebook.com/RogerBaconPuebla" target="_blank" rel="noopener noreferrer">
            Roger Bacon Puebla
          </a>.
        </p>
      </aside>
    </div>
  </section>
</BaseLayout>
