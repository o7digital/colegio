---
import Icon from './Icon.astro';
---

<footer class="site-footer">
  <div class="footer-topbar">
    <div class="container footer-topbar__inner">
      <a href="/" class="footer-brand" aria-label="Inicio Colegio Roger Bacon">
        <img src="/images/original/logo.png" alt="" width="46" height="46" />
        <span>
          <strong>Colegio Roger Bacon</strong>
          <small>Bachillerato General</small>
        </span>
      </a>

      <div class="footer-socials" aria-label="Redes sociales">
        <a href="https://www.facebook.com/RogerBaconPuebla" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
          <Icon name="facebook" class="social-icon" />
        </a>
        <a href="https://www.youtube.com/" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
          <Icon name="youtube" class="social-icon" />
        </a>
      </div>
    </div>
  </div>

  <div class="footer-band">
    <div class="container footer-grid">
      <article class="footer-item">
        <Icon name="pin" class="footer-item__icon" />
        <h2>DIRECCIÓN</h2>
        <p>Av. 16 Ote. #233, Humboldt Norte C.P. 72570 Puebla, Pue. México</p>
      </article>

      <article class="footer-item">
        <Icon name="phone" class="footer-item__icon" />
        <h2>TELÉFONO</h2>
        <p><a href="tel:+522226043466">(+052) 2226 04 34 66</a></p>
      </article>

      <article class="footer-item">
        <Icon name="mail" class="footer-item__icon" />
        <h2>CORREO</h2>
        <p><a href="mailto:contacto@colegio-rogerbacon.edu.mx">contacto@colegio-rogerbacon.edu.mx</a></p>
      </article>
    </div>
  </div>
</footer>
